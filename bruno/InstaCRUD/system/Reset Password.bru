meta {
  name: Reset Password
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/resetPassword
  body: json
  auth: inherit
}

body:json {
  {
    "token": "",
    "new_password": ""
  }
}

example {
  name: 200 Response
  description: Successful Response
  
  request: {
    url: {{baseUrl}}/api/v1/resetPassword
    method: POST
    mode: json
    body:json: {
      {
        "token": "",
        "new_password": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "message": ""
        }
      '''
    }
  }
}

example {
  name: 422 Response
  description: Validation Error
  
  request: {
    url: {{baseUrl}}/api/v1/resetPassword
    method: POST
    mode: json
    body:json: {
      {
        "token": "",
        "new_password": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 422
      text: Unprocessable Entity
    }
  
    body: {
      type: json
      content: '''
        {
          "detail": [
            {
              "loc": [],
              "msg": "",
              "type": ""
            }
          ]
        }
      '''
    }
  }
}
