meta {
  name: List Mcp Resources
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/mcp/resources
  body: json
  auth: inherit
}

body:json {
  {
    "mcp_server_url": "",
    "mcp_api_key": "",
    "uri": ""
  }
}

example {
  name: 200 Response
  description: Successful Response
  
