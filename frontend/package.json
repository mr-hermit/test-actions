{
  "name": "free-nextjs-admin-dashboard",
  "version": "2.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate-api": "node -e \"(async () => { const fs = require('fs'); const https = require('http'); const { execSync } = require('child_process'); const file = require('path').join(require('os').tmpdir(), 'openapi.json'); const url = 'http://localhost:8000/openapi.json'; const fileStream = fs.createWriteStream(file); https.get(url, res => res.pipe(fileStream).on('finish', () => { execSync(`npx openapi-typescript-codegen --input ${file} --output ./src/api --client axios`, { stdio: 'inherit' }); execSync('node scripts/add-required-fields.js', { stdio: 'inherit' }); })); })()\"",
    "test": "playwright test",
    "test:watch": "playwright test --ui",
    "test:coverage": "playwright test --reporter=html",
    "test:live": "playwright test",
    "test:jest": "jest",
    "test:ai": "jest test/ai_agent_test.ts",
    "test:tz:jest": "jest test/tz_test.ts",
    "test:lifecycle": "playwright test test/e2e/lifecycle.spec.ts",
    "test:pentest": "playwright test test/e2e/pentest.spec.ts",
    "test:tz": "playwright test test/e2e/tz.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:clean": "node -e \"require('fs').rmSync('test-results', {recursive: true, force: true}); console.log('Test results cleaned');\""
  },
