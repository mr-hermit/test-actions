# InstaCRUD VPS/ngrok Deployment Configuration
# Copy this file to .env.vps and fill in the values

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================

# For VPS with SSL (Let's Encrypt):
#   SSL_ENABLED=true
#   DOMAIN=demo.instacrud.it
#   ADMIN_EMAIL=admin@yourdomain.com (legacy: Let's Encrypt no longer sends expiration notices)
#   BASE_URL is derived as https://${DOMAIN}
#
# For ngrok (SSL terminated by ngrok):
#   SSL_ENABLED=false
#   BASE_URL=https://your-tunnel.ngrok-free.app (ngrok URL)

SSL_ENABLED=false
DOMAIN=localhost
ADMIN_EMAIL=

# BASE_URL: Usually derived from DOMAIN. Override for ngrok or custom setups.
# BASE_URL=https://your-tunnel.ngrok-free.app

# =============================================================================
# REQUIRED SECRETS
# =============================================================================

# MongoDB
MONGO_PASSWORD=your-secure-mongodb-password

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-jwt-secret-key

# =============================================================================
# OAUTH (at least one recommended)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# =============================================================================
# CLOUDFLARE TURNSTILE (anti-bot)
# =============================================================================

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_MODE=normal

# =============================================================================
# EMAIL (optional)
# =============================================================================

EMAIL_ENABLED=false
EMAIL_DRIVER=file
BREVO_API_KEY=
EMAIL_FROM_ADDRESS=noreply@instacrud.it
EMAIL_FROM_NAME=InstaCRUD

# =============================================================================
# AI FEATURES (optional)
# =============================================================================

DEEP_INFRA_KEY=

# =============================================================================
# PUBLIC SETTINGS
# =============================================================================

OPEN_REGISTRATION=false
SUGGEST_LOADING_MOCK_DATA=false
