# etalon.env

# === Mode ===
MODE="test"  # prod | test

# === BASE URLs ===
BASE_URL="http://localhost:8000"
FRONTEND_BASE_URL="http://localhost:3000"

# === JWT ===
SECRET_KEY="your_secret_key"
ALGORITHM="HS256"
TOKEN_EXPIRATION_SECONDS="86400"  # Default is 86400 seconds (24 hours)

# === Connection URL Encryption ===
# Dedicated key for encrypting org database connection URLs stored in the system DB.
# STRONGLY RECOMMENDED: set this to a separate, stable secret.
# If not set, SECRET_KEY is used as fallback — but if you ever rotate SECRET_KEY
# (e.g. after a JWT compromise), ALL encrypted org database connections will break.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
MONGO_URL_SECRET_KEY=

# === Database ===
# Supported DB_ENGINE values: mongo, atlas, firestore
DB_ENGINE="mongo"
MONGO_URL="mongodb://test:test@localhost:27017/"
MONGO_TLS_ALLOW_INVALID="False"  # Change to True if you are getting SSL certificate issues
MONGO_USE_ORG_DB="false"  # When true with mongo/atlas, use Organization.mongo_url if set

# === CORS ===
CORS_ALLOW_ORIGINS="*"
CORS_ALLOW_CREDENTIALS="False"
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# === Google OAuth ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Microsoft OAuth ===
MS_CLIENT_ID=your-microsoft-client-id
MS_CLIENT_SECRET=your-microsoft-client-secret
MS_TENANT_ID=common  # or your-tenant-id for single-tenant

# === DeepInfra API ===
DEEP_INFRA_KEY=your-deep-infra-key

# === Cloudflare Turnstile ===
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here  # leave empty or remove to disable Turnstile verification
TURNSTILE_MODE=normal  # use "normal" to see the widget or "invisible" for best UX

# === Public Settings ===
OPEN_REGISTRATION="false"
SUGGEST_LOADING_MOCK_DATA="false"  # Show option to load sample data during signup
SUGGEST_LOADING_MOCK_DATA_DEFAULT="false"  # Pre-check the "Load sample data" checkbox during signup
DEFAULT_TIER_CODE="free"  # Default tier code assigned to new organizations (leave empty to skip)

# === Usage Tracking ===
USAGE_RESET_PERIOD_SECONDS="86400"  # Default: 1 day (24 hours)

# === Search (operational tuning only) ===
SEARCH_FALLBACK_ENABLED="true"
SEARCH_FALLBACK_MIN_QUERY_LEN="3"
SEARCH_FALLBACK_LIMIT="20"

# === Index Management ===
AUTO_CREATE_SEARCH_INDEXES="false"

# === Email Configuration ===
EMAIL_ENABLED=false  # Master switch: set to true to enable sending emails
EMAIL_CARRIER=file    # 'file' | 'brevo' | 'smtp' | 'gmail'; determines which email service to use
EMAIL_DUMP_PATH=     # Path where file-driver emails are saved; defaults to system temp directory if empty

# === SMTP Configuration ===
SMTP_HOST=localhost       # Hostname of SMTP server
SMTP_PORT=587             # Port number (587 for TLS, 465 for SSL)
SMTP_USERNAME=            # Username/login for SMTP server
SMTP_PASSWORD=            # Password for SMTP server
SMTP_TLS=true             # Enable STARTTLS (recommended)
SMTP_SSL=false            # Enable implicit SSL (for port 465)

# === Gmail Configuration ===
GMAIL_USERNAME=           # Your Gmail address for sending emails
GMAIL_PASSWORD=           # 16-character App Password (required if 2FA is enabled)

# === Brevo Configuration ===
BREVO_API_KEY=            # Your Brevo (Sendinblue) API key

# === Email From / Sender Info ===
EMAIL_FROM_ADDRESS=noreply@yourdomain.com   # Sender email address shown in "From" field
EMAIL_FROM_NAME=InstaCRUD                   # Sender display name

# === Embeddings ===
DEFAULT_EMBEDDING_MODEL="intfloat/multilingual-e5-large"
